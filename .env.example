DB_USER=postgres
DB_PASSWORD=sua_senha
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=studio_mazoni_barber
# DATABASE_URL=postgres://usuario:senha@host:5432/banco
# DB_SSL=true
PORT=3000
# Identidade do negocio. Para clonar e vender, troque estes dados por cliente.
BUSINESS_NAME="Studio Mazoni Barber"
BUSINESS_SHORT_NAME="Mazoni Barber"
BUSINESS_OWNER_NAME="Franciele"
BUSINESS_INITIAL=M
BUSINESS_SEGMENT="Barbearia premium"
BUSINESS_SUBTITLE="Corte, barba e atendimento com hora marcada."
BUSINESS_REGION="Santa Tereza, Rio Grande do Sul"
BUSINESS_BOOKING_TEXT="Escolha Deryck, Leo Mazoni ou Gustavo e veja os horarios livres em tempo real."
BUSINESS_LOCATION_TITLE="Rua Abelardo Marques 180"
BUSINESS_LOCATION_DESCRIPTION="Santa Tereza, Rio Grande do Sul. Segunda 13:30-20:00, terca a sabado 09:00-20:00."
# Opcional: origens extras separadas por virgula. Para uso normal, deixe vazio e use PUBLIC_BASE_URL.
CORS_ORIGIN=
PUBLIC_BASE_URL=https://seu-dominio.com
# Para demo comercial, deixe a landing do AgendaPro na raiz e a demo cliente em /demo.
PRODUCT_LANDING_HOME=true
DEMO_CLIENT_PATH=/demo
# Exemplo para testes locais com tunel publico:
# PUBLIC_BASE_URL=https://seu-subdominio.ngrok-free.app
WHATSAPP_BUSINESS_NUMBER=5511999999999
# Opcional: numero que recebe avisos internos de pedidos manuais. Se vazio, usa WHATSAPP_BUSINESS_NUMBER.
WHATSAPP_ADMIN_NOTIFY_NUMBER=5511999999999
WHATSAPP_VERIFY_TOKEN=crie-um-token-aleatorio-para-o-webhook
WHATSAPP_ACCESS_TOKEN=token-da-whatsapp-cloud-api
WHATSAPP_PHONE_NUMBER_ID=id-do-numero-na-meta
OPENAI_API_KEY=sk-proj_sua_chave_openai
OPENAI_MODEL=gpt-4.1-mini
# Contato comercial da pagina /produto
PRODUCT_NAME=Studio Mazoni Barber
SALES_WHATSAPP_NUMBER=5511999999999
SALES_EMAIL=contato@seudominio.com
# Para teste local sem login. Em producao, o servidor ignora esta opcao.
# DISABLE_ADMIN_AUTH=true
# Legado: ainda funciona, mas prefira ADMIN_USER + ADMIN_PASSWORD_HASH em producao.
ADMIN_TOKEN=troque-esta-senha
ADMIN_USER=admin
# Gere com: npm run hash:admin
ADMIN_PASSWORD_HASH=scrypt$salt$hash
ADMIN_SESSION_SECRET=gere-um-token-aleatorio-longo

# Assina links publicos enviados por WhatsApp para confirmar/cancelar/reagendar.
# Use um segredo longo e diferente das senhas do painel em producao.
PUBLIC_ACTION_SECRET=gere-outro-token-aleatorio-longo
# ADMIN_PATH=/painel-admin-secreto
# Pagamentos online via Mercado Pago
PAYMENT_PROVIDER=mercado_pago
MERCADO_PAGO_ACCESS_TOKEN=APP_USR_sua_chave
# Opcional: use este segredo no webhook como query token ou header x-webhook-secret.
MERCADO_PAGO_WEBHOOK_SECRET=um_token_para_configurar_no_webhook
# Legado Asaas: mantenha vazio no Mazoni.
# ASAAS_ENV=sandbox
# ASAAS_API_KEY=$aact_sua_chave
# ASAAS_WEBHOOK_TOKEN=um_token_para_configurar_no_webhook
# Tempo que Pix/cartao online segura o horario enquanto aguarda pagamento.
ONLINE_PAYMENT_HOLD_MINUTES=20
# Destino padrao para repasse pelo painel admin
# BUSINESS_PIX_KEY_TYPE=EVP
# BUSINESS_PIX_KEY=chave_pix_destino
